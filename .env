# Skyesol environment template
# Copy to .env for local Netlify dev if needed:
# cp .env.example .env

# REQUIRED for admin workflows (Identity role assignment + fallback checks)
ADMIN_EMAILS=you@domain.com,ops@domain.com

# RECOMMENDED store namespace for Netlify Blobs
BLOBS_STORE=sol_growth

# OPTIONAL monitoring snapshot retention (effective clamp 20-1000)
MONITOR_HISTORY_CAP=120

# OPTIONAL base URL for metadata templating scripts
SITE_BASE_URL=https://skyesol.netlify.app
