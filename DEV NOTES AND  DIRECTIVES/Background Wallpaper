<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>Skyes Over London - Holographic Boot Background</title>

  <link rel="preconnect" href="https://fonts.googleapis.com" crossorigin>
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Share+Tech+Mono&display=swap" rel="stylesheet">

  <style>
    :root {
      --bg0: #030307;
      --bg-grid: #090a10;
      --ink: #e8ecff;
      
      --gold: #ffd36a;
      --purple: #a243ff;
      --cyan: #00f3ff;
      --cyan-dim: rgba(0, 243, 255, 0.15);

      --mono: 'Share Tech Mono', ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;
    }

    * { box-sizing: border-box; }
    html, body { height: 100%; margin: 0; padding: 0; }
    
    body {
      background: var(--bg0);
      color: var(--ink);
      font-family: var(--mono);
      -webkit-font-smoothing: antialiased;
      /* Removed overflow: hidden so your foreground website can scroll normally */
    }

    /* --- FOREGROUND APPLICATION LAYER --- */
    /* This behaves like a normal website container. Put all your HTML inside here. */
    .foreground-content {
      position: relative;
      z-index: 10; /* Keeps your content above the background */
      min-height: 100vh;
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: flex-start;
      padding: 40px;
      /* Content here will be fully clickable and scrollable */
    }

    /* --- LOOPING BACKGROUND OVERLAY --- */
    .boot-sequence {
      position: fixed; /* Locks to the screen viewport */
      inset: 0;
      z-index: -1; /* Pushed entirely behind everything else */
      background: var(--bg0);
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      perspective: 1000px;
      overflow: hidden; /* Prevents background animations from causing weird scrolling */
      pointer-events: none; /* Crucial: lets all mouse clicks pass through to your website */
    }

    /* CRT & Scanline Effects */
    .scanlines {
      position: absolute;
      inset: 0;
      background: linear-gradient(to bottom, rgba(255,255,255,0), rgba(255,255,255,0) 50%, rgba(0,0,0,0.2) 50%, rgba(0,0,0,0.2));
      background-size: 100% 4px;
      z-index: 10;
      pointer-events: none;
      opacity: 0.6;
    }
    .vignette {
      position: absolute;
      inset: 0;
      background: radial-gradient(circle at center, transparent 40%, rgba(0,0,0,0.85) 100%);
      z-index: 11;
      pointer-events: none;
    }

    /* 3D Moving Floor Grid */
    .cyber-grid {
      position: absolute;
      bottom: -30%;
      left: -50%;
      width: 200%;
      height: 100%;
      background-image: 
        linear-gradient(var(--cyan-dim) 1px, transparent 1px),
        linear-gradient(90deg, var(--cyan-dim) 1px, transparent 1px);
      background-size: 50px 50px;
      transform: rotateX(75deg);
      transform-origin: top center;
      animation: gridScroll 3s linear infinite;
      z-index: 1;
      mask-image: linear-gradient(to bottom, transparent 0%, black 40%, black 100%);
      -webkit-mask-image: linear-gradient(to bottom, transparent 0%, black 40%, black 100%);
    }
    @keyframes gridScroll {
      0% { transform: rotateX(75deg) translateY(0); }
      100% { transform: rotateX(75deg) translateY(50px); }
    }

    /* Neon Stars */
    .stars-container {
      position: absolute;
      inset: 0;
      z-index: 0; /* Deepest background layer */
      overflow: hidden;
      pointer-events: none;
    }
    .star {
      position: absolute;
      border-radius: 50%;
      background-color: #fff;
      opacity: 0;
      animation: 
        twinkle var(--twinkle-dur) var(--twinkle-del) ease-in-out infinite alternate,
        drift var(--drift-dur) linear infinite alternate;
    }
    @keyframes twinkle {
      0% { opacity: 0.1; box-shadow: 0 0 2px var(--star-color); background-color: #fff; }
      100% { opacity: 1; box-shadow: 0 0 10px var(--star-color), 0 0 25px var(--star-color); background-color: var(--star-color); }
    }
    @keyframes drift {
      0% { transform: translate(0, 0); }
      100% { transform: translate(var(--drift-x), var(--drift-y)); }
    }

    /* Main Console Area */
    .console-core {
      position: relative;
      z-index: 20;
      display: flex;
      flex-direction: column;
      align-items: center;
      width: 100%;
      max-width: 600px;
    }

    /* Holographic 3D Rings */
    .hologram-stage {
      position: relative;
      width: 480px;
      height: 480px;
      display: flex;
      align-items: center;
      justify-content: center;
      margin-bottom: 20px;
      transform-style: preserve-3d;
    }

    .holo-logo {
      width: 340px;
      position: absolute;
      z-index: 5;
      filter: drop-shadow(0 0 15px rgba(0, 243, 255, 0.4)) drop-shadow(0 0 30px rgba(162, 67, 255, 0.2));
      animation: logoFloat 4s ease-in-out infinite, logoGlitch 6s infinite;
    }

    .ring {
      position: absolute;
      border-radius: 50%;
      border: 1px solid transparent;
      box-shadow: inset 0 0 15px rgba(255,255,255,0.05), 0 0 15px rgba(255,255,255,0.05);
    }

    .ring-1 {
      width: 460px; height: 460px;
      border-top: 2px solid var(--cyan);
      border-bottom: 2px solid var(--cyan);
      animation: spinAxis1 4s linear infinite;
    }
    .ring-2 {
      width: 400px; height: 400px;
      border-left: 2px solid var(--purple);
      border-right: 2px solid var(--purple);
      animation: spinAxis2 5s linear infinite;
    }
    .ring-3 {
      width: 340px; height: 340px;
      border-top: 2px solid var(--gold);
      border-left: 2px solid var(--gold);
      animation: spinAxis3 3.5s linear infinite;
    }

    @keyframes spinAxis1 { 0% { transform: rotateX(70deg) rotateY(0deg) rotateZ(0deg); } 100% { transform: rotateX(70deg) rotateY(0deg) rotateZ(360deg); } }
    @keyframes spinAxis2 { 0% { transform: rotateX(0deg) rotateY(70deg) rotateZ(0deg); } 100% { transform: rotateX(0deg) rotateY(70deg) rotateZ(360deg); } }
    @keyframes spinAxis3 { 0% { transform: rotateX(45deg) rotateY(45deg) rotateZ(0deg); } 100% { transform: rotateX(45deg) rotateY(45deg) rotateZ(360deg); } }

    @keyframes logoFloat {
      0%, 100% { transform: translateY(0px) scale(1); }
      50% { transform: translateY(-8px) scale(1.05); }
    }
    
    @keyframes logoGlitch {
      0%, 96%, 100% { filter: drop-shadow(0 0 15px rgba(0, 243, 255, 0.4)) hue-rotate(0deg); opacity: 1; }
      97% { filter: drop-shadow(0 0 25px var(--purple)) hue-rotate(90deg); opacity: 0.8; transform: translateX(2px); }
      98% { filter: drop-shadow(0 0 25px var(--cyan)) hue-rotate(-90deg); opacity: 0.9; transform: translateX(-2px); }
      99% { filter: drop-shadow(0 0 15px var(--gold)) hue-rotate(45deg); opacity: 1; transform: translateX(0); }
    }

    /* Terminal Text Area */
    .terminal-output {
      width: 100%;
      height: 100px;
      display: flex;
      flex-direction: column;
      justify-content: flex-end;
      align-items: center;
      margin-bottom: 30px;
      position: relative;
    }

    .log-line {
      font-size: 13px;
      letter-spacing: 0.2em;
      text-transform: uppercase;
      color: rgba(255, 255, 255, 0.4);
      margin-bottom: 6px;
      transition: all 0.3s ease;
      text-align: center;
      width: 100%;
    }
    .log-line.active {
      color: var(--cyan);
      text-shadow: 0 0 8px var(--cyan);
      font-size: 14px;
    }

    .cursor {
      display: inline-block;
      width: 8px; 
      height: 15px;
      background: var(--cyan);
      margin-left: 6px;
      vertical-align: middle;
      animation: blink 0.8s step-end infinite;
      box-shadow: 0 0 10px var(--cyan);
    }
    @keyframes blink { 50% { opacity: 0; } }

    /* High-Tech Progress Bar */
    .progress-container {
      width: 320px;
      height: 4px;
      background: rgba(255, 255, 255, 0.05);
      border-radius: 2px;
      position: relative;
      box-shadow: inset 0 1px 3px rgba(0,0,0,0.8);
      overflow: hidden;
    }
    
    .progress-fill {
      position: absolute;
      top: 0; left: 0; bottom: 0;
      width: 0%;
      background: linear-gradient(90deg, transparent, var(--cyan) 50%, var(--gold) 80%, #fff 100%);
      box-shadow: 0 0 15px rgba(0, 243, 255, 0.6);
      transition: width 0.1s linear;
    }
    
    .progress-glow {
      position: absolute;
      right: 0;
      top: -3px;
      bottom: -3px;
      width: 4px;
      background: #fff;
      box-shadow: 0 0 12px 4px var(--cyan);
      border-radius: 50%;
    }

  </style>
</head>
<body>

  <!-- ========================================== -->
  <!-- FOREGROUND APP OVERLAY (YOUR WEBSITE HERE) -->
  <!-- ========================================== -->
  <div class="foreground-content">
    <!-- Place your actual website HTML structure here -->
  </div>


  <!-- ========================================== -->
  <!-- LOOPING BACKGROUND SEQUENCE (DO NOT TOUCH) -->
  <!-- ========================================== -->
  <div class="boot-sequence" id="boot-sequence">
    <div class="stars-container" id="stars-container"></div>
    <div class="scanlines"></div>
    <div class="vignette"></div>
    <div class="cyber-grid"></div>

    <div class="console-core">
      <!-- Hologram Rings & Logo -->
      <div class="hologram-stage">
        <div class="ring ring-1"></div>
        <div class="ring ring-2"></div>
        <div class="ring ring-3"></div>
        <img 
          src="https://cdn1.sharemyimage.com/2026/02/16/logo1_transparent.png" 
          alt="Skyes Over London Logo" 
          class="holo-logo"
        >
      </div>

      <!-- Terminal Output -->
      <div class="terminal-output" id="terminal"></div>

      <!-- Hardware Progress Bar -->
      <div class="progress-container">
        <div class="progress-fill" id="progress-bar">
          <div class="progress-glow"></div>
        </div>
      </div>
    </div>
  </div>

  <script>
    document.addEventListener("DOMContentLoaded", () => {
      
      const bootLines = [
        "INITIALIZING SKYES OVER LONDON EDITORIAL SHELL",
        "LOADING KAIXU GATE DELTA POSTMORTEM",
        "VERIFYING GOVERNANCE POSTURE",
        "RENDERING SUPERGATE UPGRADE LOG",
        "BYPASSING SECURITY PROTOCOLS",
        "DECRYPTING NEURAL ARCHIVE",
        "SYSTEM REBOOT INITIATED"
      ];

      const terminal = document.getElementById('terminal');
      const progressBar = document.getElementById('progress-bar');

      const chars = "ABCDEFGHIJKLMNOPQRSTUVWXYZ0123456789!@#$%^&*()_+<>?";
      const sleep = (ms) => new Promise(resolve => setTimeout(resolve, ms));

      // --- Neon Stars Generation ---
      const starsContainer = document.getElementById('stars-container');
      const colors = ['var(--cyan)', 'var(--purple)', 'var(--gold)', '#ffffff'];
      
      // Increased from 75 to 250 stars for a dense, rich background
      for (let i = 0; i < 250; i++) {
        const star = document.createElement('div');
        star.classList.add('star');
        
        // Randomize physical properties and animations
        const size = Math.random() * 3 + 1; // 1px to 4px (slightly larger max size)
        const color = colors[Math.floor(Math.random() * colors.length)];
        const posX = Math.random() * 100; // 0 to 100vw
        const posY = Math.random() * 100; // 0 to 100vh
        const twinkleDuration = Math.random() * 2 + 1; // 1s to 3s (faster, more frantic twinkle)
        const twinkleDelay = Math.random() * 5; // 0s to 5s offset
        const driftX = (Math.random() - 0.5) * 200; // wider drift distance X
        const driftY = (Math.random() - 0.5) * 200; // wider drift distance Y
        const driftDuration = Math.random() * 20 + 20; // Faster movement (20s to 40s)
        
        star.style.width = `${size}px`;
        star.style.height = `${size}px`;
        star.style.left = `${posX}%`;
        star.style.top = `${posY}%`;
        star.style.setProperty('--star-color', color);
        star.style.setProperty('--twinkle-dur', `${twinkleDuration}s`);
        star.style.setProperty('--twinkle-del', `${twinkleDelay}s`);
        star.style.setProperty('--drift-x', `${driftX}px`);
        star.style.setProperty('--drift-y', `${driftY}px`);
        star.style.setProperty('--drift-dur', `${driftDuration}s`);
        
        starsContainer.appendChild(star);
      }

      async function scrambleText(element, finalString) {
        let currentString = "";
        
        for (let i = 0; i < finalString.length; i++) {
          for (let j = 0; j < 2; j++) {
            let randomChar = chars[Math.floor(Math.random() * chars.length)];
            element.innerHTML = currentString + randomChar + '<span class="cursor"></span>';
            await sleep(15);
          }
          currentString += finalString[i];
          element.innerHTML = currentString + '<span class="cursor"></span>';
          
          updateProgress(finalString.length, i);
        }
      }

      let totalChars = bootLines.join("").length;
      let charsTyped = 0;

      function updateProgress(lineLength, charIndex) {
        charsTyped++;
        let percent = (charsTyped / totalChars) * 100;
        progressBar.style.width = `${percent}%`;
      }

      async function runBootSequence() {
        charsTyped = 0;
        terminal.innerHTML = '';
        
        progressBar.style.transition = 'none';
        progressBar.style.width = '0%';
        void progressBar.offsetWidth; 
        progressBar.style.transition = 'width 0.1s linear';
        
        const logElements = [];

        for (let i = 0; i < bootLines.length; i++) {
          if (logElements.length > 0) {
            logElements[logElements.length - 1].classList.remove('active');
            logElements[logElements.length - 1].innerHTML = logElements[logElements.length - 1].innerText; 
          }

          const lineEl = document.createElement('div');
          lineEl.className = 'log-line active';
          terminal.appendChild(lineEl);
          logElements.push(lineEl);

          if (logElements.length > 3) {
            logElements[logElements.length - 4].style.display = 'none';
          }

          await scrambleText(lineEl, bootLines[i]);
          
          if (i !== bootLines.length - 1) {
            await sleep(400); 
          } else {
            progressBar.style.width = '100%';
            await sleep(2500);
          }
        }

        terminal.style.transition = 'opacity 0.6s ease-out';
        terminal.style.opacity = '0';
        
        await sleep(700);
        
        terminal.style.opacity = '1';
        terminal.style.transition = ''; 

        runBootSequence();
      }

      setTimeout(() => {
        runBootSequence();
      }, 500);

    });
  </script>
</body>
</html>