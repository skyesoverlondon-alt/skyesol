  <script>
    (function(){
      // Release body scroll after opener
      window.addEventListener('load', () => {
        setTimeout(() => { document.body.classList.remove('locked'); }, 5200);
      });

      // Nav scroll effect
      const nav = document.getElementById('nav');
      const onScrollNav = () => {
        if (window.scrollY > 40) nav.classList.add('scrolled');
        else nav.classList.remove('scrolled');
      };
      window.addEventListener('scroll', onScrollNav, { passive:true });
      onScrollNav();

      // Date stamp (local)
      const d = new Date();
      const months = ["January","February","March","April","May","June","July","August","September","October","November","December"];
      const stamp = months[d.getMonth()] + " " + String(d.getDate()).padStart(2,'0') + ", " + d.getFullYear();
      const dateEl = document.getElementById('articleDate');
      if (dateEl) dateEl.textContent = stamp;

      // Intersection Observer for scroll animations
      const io = new IntersectionObserver((entries) => {
        entries.forEach(e => {
          if (!e.isIntersecting) return;
          e.target.classList.add('visible');
          io.unobserve(e.target);
        });
      }, { threshold: 0.15 });

      document.querySelectorAll('.fade-up, .stat-item, .animated-list li').forEach(el => io.observe(el));

      // Count-up for stat numbers (only numeric)
      const countUp = (el, target) => {
        const dur = 900;
        const start = performance.now();
        const from = 0;
        const tick = (t) => {
          const p = Math.min(1, (t - start) / dur);
          const eased = 1 - Math.pow(1 - p, 3);
          const val = Math.round(from + (target - from) * eased);
          el.textContent = String(val);
          if (p < 1) requestAnimationFrame(tick);
        };
        requestAnimationFrame(tick);
      };

      const cio = new IntersectionObserver((entries) => {
        entries.forEach(e => {
          if (!e.isIntersecting) return;
          const el = e.target;
          const target = parseInt(el.getAttribute('data-count') || '0', 10);
          if (Number.isFinite(target)) countUp(el, target);
          cio.unobserve(el);
        });
      }, { threshold: 0.6 });

      document.querySelectorAll('.stat-number[data-count]').forEach(el => cio.observe(el));

      // Smooth scroll for internal anchors
      document.querySelectorAll('a[href^="#"]').forEach(a => {
        a.addEventListener('click', (ev) => {
          const href = a.getAttribute('href');
          if (!href || href.length < 2) return;
          const target = document.querySelector(href);
          if (!target) return;
          ev.preventDefault();
          target.scrollIntoView({ behavior:'smooth', block:'start' });
        });
      });

      // Sidebar active link highlight
      const sections = Array.from(document.querySelectorAll('section[id]'));
      const sidebarLinks = Array.from(document.querySelectorAll('.sidebar-nav a[href^="#"]'));
      const linkMap = new Map(sidebarLinks.map(a => [a.getAttribute('href').slice(1), a]));
      if (sidebarLinks.length && sections.length){
        const sio = new IntersectionObserver((entries) => {
          const v = entries.filter(e => e.isIntersecting).sort((a,b)=>b.intersectionRatio-a.intersectionRatio)[0];
          if (!v) return;
          sidebarLinks.forEach(a => a.classList.remove('active'));
          const id = v.target.id;
          const l = linkMap.get(id);
          if (l) l.classList.add('active');
        }, { threshold: [0.2, 0.35, 0.5, 0.65] });

        sections.forEach(s => sio.observe(s));
      }

      // Stars canvas (lightweight)
      const canvas = document.getElementById('stars');
      if (canvas){
        const ctx = canvas.getContext('2d', { alpha:true });
        const DPR = Math.min(2, window.devicePixelRatio || 1);
        let W=0,H=0,stars=[];

        function resize(){
          W = canvas.clientWidth;
          H = canvas.clientHeight;
          canvas.width = Math.floor(W * DPR);
          canvas.height = Math.floor(H * DPR);
          ctx.setTransform(DPR,0,0,DPR,0,0);
          const n = Math.max(80, Math.round((W*H)/9000));
          stars = new Array(n).fill(0).map(()=>({
            x: Math.random()*W,
            y: Math.random()*H,
            r: Math.random()*1.3 + 0.2,
            v: Math.random()*0.25 + 0.05,
            a: Math.random()*0.55 + 0.12,
            hue: Math.random() < 0.05 ? "gold" : (Math.random() < 0.10 ? "cyan" : (Math.random() < 0.06 ? "purple" : "white"))
          }));
        }

        function dot(s){
          let color = `rgba(255,255,255,${s.a})`;
          if (s.hue === "gold") color = `rgba(255,211,106,${s.a*0.9})`;
          if (s.hue === "cyan") color = `rgba(39,242,255,${s.a*0.85})`;
          if (s.hue === "purple") color = `rgba(162,67,255,${s.a*0.75})`;
          ctx.beginPath();
          ctx.arc(s.x, s.y, s.r, 0, Math.PI*2);
          ctx.fillStyle = color;
          ctx.fill();
        }

        let t0 = performance.now();
        function frame(t){
          const dt = Math.min(33, t - t0); t0 = t;
          ctx.clearRect(0,0,W,H);

          const g1 = ctx.createRadialGradient(W*0.25, H*0.18, 10, W*0.25, H*0.18, Math.max(W,H)*0.65);
          g1.addColorStop(0, "rgba(162,67,255,0.10)");
          g1.addColorStop(1, "rgba(162,67,255,0.00)");
          ctx.fillStyle = g1; ctx.fillRect(0,0,W,H);

          const g2 = ctx.createRadialGradient(W*0.78, H*0.22, 10, W*0.78, H*0.22, Math.max(W,H)*0.60);
          g2.addColorStop(0, "rgba(39,242,255,0.08)");
          g2.addColorStop(1, "rgba(39,242,255,0.00)");
          ctx.fillStyle = g2; ctx.fillRect(0,0,W,H);

          const g3 = ctx.createRadialGradient(W*0.62, H*0.88, 10, W*0.62, H*0.88, Math.max(W,H)*0.62);
          g3.addColorStop(0, "rgba(255,211,106,0.07)");
          g3.addColorStop(1, "rgba(255,211,106,0.00)");
          ctx.fillStyle = g3; ctx.fillRect(0,0,W,H);

          for (const s of stars){
            s.y += s.v * (dt/16.7);
            if (s.y > H + 2){ s.y = -2; s.x = Math.random()*W; }
            dot(s);
          }
          requestAnimationFrame(frame);
        }

        const ro = new ResizeObserver(resize);
        ro.observe(canvas);
        resize();
        requestAnimationFrame(frame);
      }
    })();
  </script>

