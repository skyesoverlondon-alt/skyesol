# ============================================================
# kAIxuGateway13 — Complete Environment Variables Reference
# Hosted on: https://skyesol.netlify.app
# ============================================================
# QUICK START FOR THIS SKYESOL BUILD:
#   Required database env: NEON_DATABASE_URL
#   Optional fallbacks still accepted by code: DATABASE_URL, NETLIFY_DATABASE_URL
#   Netlify Blobs: no manual env var required in this build
#   Netlify Identity: no env var required, but enable it in Netlify site settings
#   Identity roles in use: president, vp, cfo, team_owner, player
# HOW TO USE:
#   Netlify Dashboard → Site → Site configuration → Environment variables
#   Add each variable below that applies to your deployment.
#
# AUTO-INJECTED BY NETLIFY (do NOT set these manually in production):
#   NETLIFY_DATABASE_URL          — injected by Neon when you attach the DB extension (fallback only here)
#   NETLIFY_DATABASE_URL_UNPOOLED — injected by Neon alongside the above
#   URL                           — injected by Netlify (your site's primary URL)
#   DEPLOY_URL                    — injected by Netlify (branch deploy URL)
#   DEPLOY_PRIME_URL              — injected by Netlify (main site URL for function context)
# ============================================================


# ─────────────────────────────────────────────
# SECTION 0 — CORE SKYESOL DATABASE CONTRACT
# ─────────────────────────────────────────────

# Primary shared database for the entire Skyesol site and connected products.
# This is the one env var you actually need for this build.
NEON_DATABASE_URL="postgres://user:pass@host:5432/dbname"

# Optional fallback names only. Leave blank unless you intentionally need them.
DATABASE_URL=""
NETLIFY_DATABASE_URL=""


# ─────────────────────────────────────────────
# SECTION 1 — REQUIRED (gateway will not boot without these)
# ─────────────────────────────────────────────

# Admin dashboard password — used to obtain an admin JWT via /admin-login
ADMIN_PASSWORD="CHANGE_ME_TO_A_STRONG_PASSWORD"

# JWT signing secret — signs all admin JWTs and user session tokens
# Must be 64+ random characters. Changing this invalidates all existing sessions.
JWT_SECRET="PASTE_A_LONG_RANDOM_SECRET_64+CHARS_HERE"

# CORS origin allowlist
# Use "*" during initial setup/testing.
# Production: comma-separated exact origins that will call the gateway.
ALLOWED_ORIGINS="https://skyesol.netlify.app"

# AI Provider API keys — set at least ONE
OPENAI_API_KEY=""
ANTHROPIC_API_KEY=""
GEMINI_API_KEY=""


# ─────────────────────────────────────────────
# SECTION 2 — GOVERNANCE / BILLING DEFAULTS
# ─────────────────────────────────────────────

# Default monthly spend cap per customer, in cents (e.g. 2000 = $20.00)
# Overridable per-customer via admin panel.
DEFAULT_CUSTOMER_CAP_CENTS="2000"

# Default requests-per-minute limit per API key
# Overridable per-key via admin panel.
DEFAULT_RPM_LIMIT="120"

# Send a webhook alert when a customer's usage crosses this % of their cap
# Requires ALERT_WEBHOOK_URL to be set.
CAP_WARN_PCT="85"
ALERT_WEBHOOK_URL=""

# User session token TTL in seconds (default = 6 hours)
USER_SESSION_TTL_SECONDS="21600"


# ─────────────────────────────────────────────
# SECTION 3 — SECURITY (recommended for production)
# ─────────────────────────────────────────────

# Encrypt sensitive fields stored in DB (per-customer tokens, OAuth tokens, etc.)
# Use a DIFFERENT value from JWT_SECRET. Falls back to JWT_SECRET if unset.
DB_ENCRYPTION_KEY="PASTE_A_DIFFERENT_LONG_RANDOM_SECRET_64+CHARS"

# Extra entropy added to API key hashing (defense-in-depth)
KEY_PEPPER="PASTE_A_LONG_RANDOM_SECRET_64+CHARS"

# Force JWT-only admin auth (disables X-Admin-Password header shortcut)
# Set "true" once you confirm admin login works.
DISABLE_ADMIN_PASSWORD_HEADER="true"

# Secret token required to call /.netlify/functions/client-error-report
# If unset, the endpoint remains open.
CLIENT_ERROR_TOKEN=""

# Secret required to unlock /admin-menu.html (site-wide path inventory)
DEMONKEY="CHANGE_ME_TO_A_STRONG_SECRET"

# Secret required by internal background workers (prevents unauthorized job triggering)
JOB_WORKER_SECRET="PASTE_A_LONG_RANDOM_SECRET_64+CHARS"


# ─────────────────────────────────────────────
# SECTION 4 — RATE LIMITING AT SCALE (optional)
# DB rate limiting works out of the box.
# Add Upstash Redis for higher-throughput, lower-latency limiting.
# ─────────────────────────────────────────────

UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""


# ─────────────────────────────────────────────
# SECTION 5 — ASYNC JOB RETENTION (scheduled daily)
# ─────────────────────────────────────────────

ASYNC_JOB_SUCCESS_RETENTION_DAYS="7"
ASYNC_JOB_RETENTION_DAYS="30"


# ─────────────────────────────────────────────
# SECTION 6 — KAIXUPUSH (deploy operations)
# ─────────────────────────────────────────────

PUSH_CHUNK_RETENTION_HOURS="48"
PUSH_NETLIFY_MAX_DEPLOYS_PER_MIN="3"
PUSH_NETLIFY_MAX_DEPLOYS_PER_DAY="100"
PUSH_UPLOAD_INLINE_RETRIES="3"
PUSH_JOB_MAX_ATTEMPTS="10"
PUSH_JOB_RETRY_BASE_MS="750"
PUSH_JOB_RETRY_MAX_MS="30000"

# Global Netlify PAT fallback (optional — preferred: store per-customer in DB via admin)
NETLIFY_AUTH_TOKEN=""


# ─────────────────────────────────────────────
# SECTION 7 — GITHUB PUSH GATEWAY (optional)
# ─────────────────────────────────────────────

# Option A — GitHub OAuth App (recommended for multi-user)
# Create at: https://github.com/settings/applications/new
# Callback URL: https://skyesol.netlify.app/.netlify/functions/github-oauth-callback
GITHUB_CLIENT_ID=""
GITHUB_CLIENT_SECRET=""
GITHUB_OAUTH_REDIRECT_URL="https://skyesol.netlify.app/.netlify/functions/github-oauth-callback"

# GitHub API settings (defaults are correct for github.com)
GITHUB_API_BASE="https://api.github.com"
GITHUB_API_VERSION="2022-11-28"

# Safety limits for GitHub push jobs
GITHUB_PUSH_MAX_FILES="3000"
GITHUB_PUSH_MAX_TOTAL_BYTES="104857600"
GITHUB_PUSH_MAX_FILE_BYTES="10485760"

# Retry settings
GITHUB_JOB_MAX_ATTEMPTS="10"
GITHUB_JOB_RETRY_BASE_MS="1000"
GITHUB_JOB_RETRY_MAX_MS="60000"
GITHUB_CHUNK_RETENTION_HOURS="48"


# ─────────────────────────────────────────────
# SECTION 8 — STRIPE TOP-UPS (optional)
# ─────────────────────────────────────────────

STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""
STRIPE_CURRENCY="usd"
PUBLIC_APP_ORIGIN="https://skyesol.netlify.app"

# Override redirect URLs explicitly (takes priority over PUBLIC_APP_ORIGIN)
STRIPE_SUCCESS_URL=""
STRIPE_CANCEL_URL=""


# ─────────────────────────────────────────────
# SECTION 8B — SKYEFUEL STATION (public station + separate brain gate)
# ─────────────────────────────────────────────

# Public-facing station route lives at /skyefuelstation/
# Gateway 13 admin can read local station metrics immediately.
# To bridge a separate Cloudflare Worker brain gate, set the URLs below.
SKYEFUEL_STATION_BRAIN_URL=""
SKYEFUEL_STATION_BRAIN_PUBLIC_URL=""
SKYEFUEL_STATION_BRAIN_ADMIN_TOKEN=""

# Pricing policy. Keep discount configurable instead of hardcoding assumptions.
SKYEFUEL_STATION_BONUS_RETURN_PCT="23"
SKYEFUEL_STATION_DISCOUNT_PCT="0"

# Optional display labels
SKYEFUEL_STATION_FUEL_ASSET_NAME="SkyeFuel"
SKYEFUEL_STATION_SERVICE_ASSET_NAME="SkyeTokens"
SKYEFUEL_STATION_COIN_ASSET_NAME="SkyeCoins"
SKYEFUEL_STATION_ACCESS_ASSET_NAME="Kaixu Keys"

# Optional public pricing anchors for station previews
SKYEFUEL_STATION_FUEL_USD="1"
SKYEFUEL_STATION_TOKEN_USD="1"
SKYEFUEL_STATION_COIN_USD="1"
SKYEFUEL_STATION_KEY_SESSION_USD="25"


# ─────────────────────────────────────────────
# SECTION 9 — MONITORING / ARCHIVE
# ─────────────────────────────────────────────

MONITOR_ARCHIVE_STORE="blobs"
MONITOR_ARCHIVE_BATCH_SIZE="500"
MONITOR_ARCHIVE_MAX_BATCHES="20"
MONITOR_RETENTION_DAYS="30"


# ─────────────────────────────────────────────
# SECTION 10 — VOICE / TWILIO (optional)
# Webhooks:
#   /.netlify/functions/voice-twilio-inbound
#   /.netlify/functions/voice-twilio-turn
#   /.netlify/functions/voice-twilio-status
# ─────────────────────────────────────────────

TWILIO_ACCOUNT_SID="ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
TWILIO_AUTH_TOKEN="your_twilio_auth_token"
VOICE_FALLBACK_TRANSFER_NUMBER="+14804695416"
VOICE_AI_RELAY_USD_PER_MIN="0.07"
VOICE_TELEPHONY_USD_PER_MIN="0.0085"
VOICE_RECORDING_USD_PER_MIN="0.0025"
VOICE_MARKUP_PCT="31"


