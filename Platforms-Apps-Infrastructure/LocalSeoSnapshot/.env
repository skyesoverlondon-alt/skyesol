# .env.example
# Local SEO Snapshot — Environment Variables
# Required: NONE
# This file is mainly for documentation / future upgrades.
#
# IMPORTANT:
# - Netlify production env vars must be set in Netlify UI:
#   Site settings → Environment variables
# - This app currently does not *require* any of these to function.

# Optional future controls (NOT required, currently not read by code)
# ERROR_REPORT_LOG_LEVEL=info
# ERROR_REPORT_MAX_BODY_BYTES=200000
# ERROR_REPORT_SAMPLE_RATE=1.0

# If you later add simple auth to the error-report endpoint:
# ERROR_REPORT_SHARED_SECRET=replace_me_with_a_long_random_value

# If you later lock down allowed origins:
# ERROR_REPORT_ALLOW_ORIGIN=*