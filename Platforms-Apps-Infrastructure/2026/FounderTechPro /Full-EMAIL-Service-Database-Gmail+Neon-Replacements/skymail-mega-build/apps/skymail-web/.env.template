# SkyMail web app database.
# Point this at a SkyeDB/Hetzner PostgreSQL instance provisioned for the mail app.
SKYMAIL_DATABASE_URL=postgres://...

JWT_SECRET=replace_with_a_long_random_secret
PUBLIC_BASE_URL=https://your-skymail-site.netlify.app

# Public mailbox domains users can claim.
SKYMAIL_PUBLIC_DOMAINS=mail.skymail.yourdomain.com
SKYMAIL_PRIMARY_DOMAIN=mail.skymail.yourdomain.com
SKYMAIL_DEFAULT_QUOTA_MB=1024

# IMAP / SMTP runtime for your Stalwart mail authority.
SKYMAIL_IMAP_HOST=mail.your-stalwart-host.com
SKYMAIL_IMAP_PORT=993
SKYMAIL_IMAP_SECURE=true
SKYMAIL_SMTP_HOST=mail.your-stalwart-host.com
SKYMAIL_SMTP_PORT=465
SKYMAIL_SMTP_SECURE=true

# Optional custom folder names.
SKYMAIL_FOLDER_INBOX=INBOX
SKYMAIL_FOLDER_SENT=Sent
SKYMAIL_FOLDER_DRAFTS=Drafts
SKYMAIL_FOLDER_SPAM=Junk
SKYMAIL_FOLDER_TRASH=Trash
SKYMAIL_FOLDER_ARCHIVE=Archive

# Stalwart management API.
STALWART_BASE_URL=https://mail.your-stalwart-host.com
STALWART_MANAGEMENT_API_KEY=replace_with_stalwart_management_api_key
STALWART_MANAGEMENT_AUTH_HEADER=Authorization
STALWART_MANAGEMENT_AUTH_PREFIX=Bearer

# Optional: bootstrap this app database from your SkyeDB control plane.
SKYEDB_API_BASE=https://your-control-plane.workers.dev
SKYEDB_BOOTSTRAP_TOKEN=replace_with_bootstrap_token
SKYEDB_ORG_NAME=SkyMail Platform
SKYEDB_PROJECT_NAME=SkyMail Host
SKYEDB_ENV_NAME=production
SKYEDB_DB_NAME=skymail-app
SKYEDB_PLAN_CODE=starter
