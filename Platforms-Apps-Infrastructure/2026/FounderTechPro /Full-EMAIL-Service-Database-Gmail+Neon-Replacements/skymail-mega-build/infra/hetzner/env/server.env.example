POSTGRES_SUPERUSER=skyeadmin
POSTGRES_SUPERPASSWORD=change-this-now
CONTROL_DB_NAME=skyedb_control

CONTROL_DATABASE_URL=postgres://skyeadmin:change-this-now@postgres:5432/skyedb_control
DATA_DATABASE_URL=postgres://skyeadmin:change-this-now@postgres:5432/postgres

APP_ENCRYPTION_KEY=replace-with-long-random-secret
PUBLIC_DB_HOST=db.example.com
PUBLIC_DB_PORT=5432
PUBLIC_DB_SSLMODE=require

RUNNER_ID=hetzner-runner-1
POLL_INTERVAL_MS=4000
BACKUP_TEMP_DIR=/tmp/skyedb-backups

R2_ENDPOINT=https://YOUR_ACCOUNT_ID.r2.cloudflarestorage.com
R2_REGION=auto
R2_ACCESS_KEY_ID=replace-me
R2_SECRET_ACCESS_KEY=replace-me
R2_BUCKET=skye-db-backups
