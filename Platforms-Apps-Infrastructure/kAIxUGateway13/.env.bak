DISABLE_ADMIN_PASSWORD_HEADER="false"

# Secret token required to call /.netlify/functions/client-error-report
# If unset, the endpoint remains open.
CLIENT_ERROR_TOKEN="MgrWc7SaPysWBJKyqlH3IqfxteV1Dm5J3LnFAwizYW5XConGut8o3Jadc0rOFUPZS9F4_Oxee2F6egSOba0kvIUY3OqADhG5VfHsA8f2x2Ijj3ED1dU1u1BHYFf9SIqWZLb08Jf7s4fDgRxLCzLxk5wF6NUJQeLOqS_6XL3U_U8"

