# ============================================================
# kAIxuGateway13 via SkyeSol.netlify.app — Complete Environment Variables Reference
# Hosted on: https://skyesol.netlify.app
# ============================================================
# HOW TO USE:
#   Netlify Dashboard → Site → Site configuration → Environment variables
#   Add each variable below that applies to your deployment.
#
# AUTO-INJECTED BY NETLIFY (do NOT set these manually in production):
#   NETLIFY_DATABASE_URL          — injected by Neon when you attach the DB extension
#   NETLIFY_DATABASE_URL_UNPOOLED — injected by Neon alongside the above
#   URL                           — injected by Netlify (your site's primary URL)
#   DEPLOY_URL                    — injected by Netlify (branch deploy URL)
#   DEPLOY_PRIME_URL              — injected by Netlify (main site URL for function context)
# ============================================================


# ─────────────────────────────────────────────
# SECTION 1 — REQUIRED (gateway will not boot without these)
# ─────────────────────────────────────────────

# Admin dashboard password — used to obtain an admin JWT via /admin-login
ADMIN_PASSWORD="DemonLordAtreyuxh"

# JWT signing secret — signs all admin JWTs and user session tokens
# Must be 64+ random characters. Changing this invalidates all existing sessions.
JWT_SECRET="h0K0P00H647-190yt3ighe1DemonLordAtreyuxhBows4N00Entit33IlyAh0K0P00H647-190yt3ighe163564"

# CORS origin allowlist
# Use "*" during initial setup/testing.
# Production: comma-separated exact origins that will call the gateway.
ALLOWED_ORIGINS="*"

# AI Provider API keys — set at least ONE
OPENAI_API_KEY="YOUR_OPENAI_KEY_HERE
ANTHROPIC_API_KEY="YOUR_ANTHROPIC_KEY_HERE"
GEMINI_API_KEY="YOUR_GEMINI_KEY_HERE"

# ─────────────────────────────────────────────
# SECTION 2 — GOVERNANCE / BILLING DEFAULTS
# ─────────────────────────────────────────────

# Default monthly spend cap per customer, in cents (e.g. 2000 = $20.00)
# Overridable per-customer via admin panel.
DEFAULT_CUSTOMER_CAP_CENTS="2000"

# Default requests-per-minute limit per API key
# Overridable per-key via admin panel.
DEFAULT_RPM_LIMIT="120"

# Send a webhook alert when a customer's usage crosses this % of their cap
# Requires ALERT_WEBHOOK_URL to be set.
CAP_WARN_PCT="85"
ALERT_WEBHOOK_URL=""

# User session token TTL in seconds (default = 6 hours)
USER_SESSION_TTL_SECONDS="21600"


# ─────────────────────────────────────────────
# SECTION 3 — SECURITY (recommended for production)
# ─────────────────────────────────────────────

# Encrypt sensitive fields stored in DB (per-customer tokens, OAuth tokens, etc.)
# Use a DIFFERENT value from JWT_SECRET. Falls back to JWT_SECRET if unset.
DB_ENCRYPTION_KEY="VtEr98XIK8bY6-I1Pexp77y2aDFmLnhY3NoKjpsnnlPt6rGHKicnOxuR8aMnjhvrJ3AVhJUIvof_MXlvWqBafvDYj9sNR58stlVy4bWw9l8PfOhHLY_fsSpHGQ7jZ1fRYE0vcn7OD6EKls1aIEd16GA0kSkQieD9SgiNbV6-RHE"

# Extra entropy added to API key hashing (defense-in-depth)
KEY_PEPPER="MgrWc7SaPysWBJKyqlH3IqfxteV1Dm5J3LnFAwizYW5XConGut8o3Jadc0rOFUPZS9F4_Oxee2F6egSOba0kvIUY3OqADhG5VfHsA8f2x2Ijj3ED1dU1u1BHYFf9SIqWZLb08Jf7s4fDgRxLCzLxk5wF6NUJQeLOqS_6XL3U_U8"

