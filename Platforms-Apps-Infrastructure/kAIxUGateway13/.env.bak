# ─────────────────────────────────────────────
# SECTION 4 — RATE LIMITING AT SCALE (optional)
# DB rate limiting works out of the box.
# Add Upstash Redis for higher-throughput, lower-latency limiting.
# ─────────────────────────────────────────────

UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""


# ─────────────────────────────────────────────
# SECTION 5 — ASYNC JOB RETENTION (scheduled daily)
# ─────────────────────────────────────────────

ASYNC_JOB_SUCCESS_RETENTION_DAYS="7"
ASYNC_JOB_RETENTION_DAYS="30"


# ─────────────────────────────────────────────
# SECTION 6 — KAIXUPUSH (deploy operations)
# ─────────────────────────────────────────────

PUSH_CHUNK_RETENTION_HOURS="48"
PUSH_NETLIFY_MAX_DEPLOYS_PER_MIN="3"
PUSH_NETLIFY_MAX_DEPLOYS_PER_DAY="100"
PUSH_UPLOAD_INLINE_RETRIES="3"
PUSH_JOB_MAX_ATTEMPTS="10"
PUSH_JOB_RETRY_BASE_MS="750"
PUSH_JOB_RETRY_MAX_MS="30000"

# Global Netlify PAT fallback (optional — preferred: store per-customer in DB via admin)
NETLIFY_AUTH_TOKEN="nfp_cydwizf1fHxhigsLetxhdRq8rZeLfRMoe023"


# ─────────────────────────────────────────────
# SECTION 7 — GITHUB PUSH GATEWAY (optional)
# ─────────────────────────────────────────────

# Option A — GitHub OAuth App (recommended for multi-user)
# Create at: https://github.com/settings/applications/new
# Callback URL: https://skyesol.netlify.app/.netlify/functions/github-oauth-callback
GITHUB_CLIENT_ID=""
GITHUB_CLIENT_SECRET=""
GITHUB_OAUTH_REDIRECT_URL="https://skyesol.netlify.app/.netlify/functions/github-oauth-callback"

# GitHub API settings (defaults are correct for github.com)
GITHUB_API_BASE="https://api.github.com"
GITHUB_API_VERSION="2022-11-28"

# Safety limits for GitHub push jobs
GITHUB_PUSH_MAX_FILES="3000"
GITHUB_PUSH_MAX_TOTAL_BYTES="104857600"
GITHUB_PUSH_MAX_FILE_BYTES="10485760"

# Retry settings
GITHUB_JOB_MAX_ATTEMPTS="10"
GITHUB_JOB_RETRY_BASE_MS="1000"
GITHUB_JOB_RETRY_MAX_MS="60000"
GITHUB_CHUNK_RETENTION_HOURS="48"


# ─────────────────────────────────────────────
# SECTION 8 — STRIPE TOP-UPS (optional)
# ─────────────────────────────────────────────

STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""
STRIPE_CURRENCY="usd"
PUBLIC_APP_ORIGIN="https://skyesol.netlify.app"

# Override redirect URLs explicitly (takes priority over PUBLIC_APP_ORIGIN)
STRIPE_SUCCESS_URL=""
STRIPE_CANCEL_URL=""


# ─────────────────────────────────────────────
# SECTION 9 — MONITORING / ARCHIVE
# ─────────────────────────────────────────────

MONITOR_ARCHIVE_STORE="blobs"
MONITOR_ARCHIVE_BATCH_SIZE="500"
MONITOR_ARCHIVE_MAX_BATCHES="20"
MONITOR_RETENTION_DAYS="30"


